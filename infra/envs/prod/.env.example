# Example for loading Terraform variables from a .env file (paths relative to this env dir).
# Terraform reads env vars named TF_VAR_<variable_name>.
#
# From bash/zsh:
#   set -a && source .env && set +a
#   terraform plan
#
# TF_VAR_license=
# TF_VAR_env=
# TF_VAR_aws_region=
# TF_VAR_superset_acm_certificate_arn=
# TF_VAR_superset_ingress_host=
# TF_VAR_superset_init_admin_password=
# Optional; if unset, Redis password is generated and kept in Terraform state:
# TF_VAR_superset_redis_password=
