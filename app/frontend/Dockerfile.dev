# syntax=docker/dockerfile:1.7
FROM node:20-alpine
WORKDIR /app

# Install deps based on package.json; bind mount in compose overrides /app
# but node_modules is preserved via anonymous volume.
COPY package.json ./
RUN npm install --no-audit --no-fund

COPY . .
ENV NEXT_TELEMETRY_DISABLED=1
EXPOSE 3000
CMD ["npm", "run", "dev"]
